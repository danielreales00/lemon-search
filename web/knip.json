{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/{page,layout,template,loading,error,not-found,route,default}.{ts,tsx}",
    "app/**/{actions,opengraph-image,twitter-image,sitemap,robots,manifest}.{ts,tsx}",
    "next.config.ts",
    "middleware.ts"
  ],
  "project": ["**/*.{ts,tsx}"],
  "ignore": [".next/**", "out/**", "node_modules/**", "next-env.d.ts"],
  "ignoreDependencies": [
    "eslint-config-next",
    "eslint-config-prettier",
    "eslint-import-resolver-typescript"
  ],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "error",
    "types": "error",
    "duplicates": "error"
  }
}

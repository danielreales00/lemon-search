# --- API (Go service) ---
LEMON_API_PORT=8080
LEMON_API_HOST=0.0.0.0
LEMON_LOG_LEVEL=info

# Supabase / Postgres
# Local dev (recommended): `make db-up` runs Supabase's Postgres in Docker on :54322.
# This default URL matches the Supabase CLI local superuser:
LEMON_DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres?sslmode=disable
# Cloud: replace with the direct connection string from Supabase settings → Database.

# Fixed "current time" for open-status signal in dev/test.
# Format: RFC3339. Comment out in production to use time.Now().
LEMON_NOW_OVERRIDE=2026-05-27T13:00:00-04:00

# Fixed user location (a downtown Miami point) — overridable per-request.
LEMON_DEFAULT_LAT=25.7741728
LEMON_DEFAULT_LNG=-80.19362

# Path to ranking config (relative to repo root or absolute).
LEMON_RANKING_CONFIG=config/ranking.yaml

# --- Web (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

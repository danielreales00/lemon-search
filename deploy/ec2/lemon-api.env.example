# /etc/lemon/lemon-api.env — runtime config for the lemon-api systemd service.
# setup.sh writes this from the example (substituting the model/repo paths);
# fill in the secrets below, then: sudo systemctl restart lemon-api.

# --- REQUIRED: Supabase direct connection string (port 5432, not the pooler) ---
LEMON_DATABASE_URL=postgresql://postgres:CHANGE_ME@db.CHANGE_ME.supabase.co:5432/postgres

# --- REQUIRED: lock CORS to the deployed web origin (default "*" is dev-only) ---
LEMON_CORS_ALLOW_ORIGIN=https://your-app.vercel.app

# --- semantic recall (ADR-0006) via the in-process ORT embedder ---
LEMON_FF_SEMANTIC=true
LEMON_FF_INTENT=true
LEMON_EMBED_BACKEND=onnx
LEMON_ONNX_MODEL_PATH=__MODEL_DIR__
LEMON_ONNX_RUNTIME_DIR=/usr/lib
# Embed pipeline pool (#107): keep ≈ vCPUs. c7i.xlarge = 4.
LEMON_EMBED_POOL_SIZE=4

# --- server ---
LEMON_API_PORT=8080
LEMON_RANKING_CONFIG=__REPO_DIR__/config/ranking.yaml
LEMON_LOG_LEVEL=info
# Optional: pgx pool size. Empty = pgx default (max(4, numCPU)). Raise if the
# Supabase tier is co-scaled up for a load test (see docs/bench/plan.md).
# LEMON_DB_MAX_CONNS=20
